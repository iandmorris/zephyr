config SOC_SERIES_RA6M4
	bool "Renesas RA6M4"
	select ARM
	select CPU_CORTEX_M33
	select CPU_HAS_ARM_MPU
	select CPU_CORTEX_M_HAS_SYSTICK
	select DYNAMIC_INTERRUPTS
	select SOC_FAMILY_RA
	select TIMER_READS_ITS_FREQUENCY_AT_RUNTIME
	select XIP
