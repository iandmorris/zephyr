config SOC_SERIES_RA6M5
	bool
	select SOC_FAMILY_RENESAS_RA
	help
	  Renesas RA6M5

config SOC_R7FA6M5BH2CBG
	bool
	select SOC_SERIES_RA6M5
	help
	  R7FA6M5BH2CBG

config SOC_SERIES
	default "ra6m5" if SOC_SERIES_RA6M5

config SOC
	default "r7fa6m5bh2cbg" if SOC_R7FA6M5BH2CBG
