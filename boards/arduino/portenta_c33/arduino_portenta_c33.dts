/dts-v1/;

#include <zephyr/dt-bindings/gpio/gpio.h>

#include "arduino_uno_r4_common.dtsi"
#include "arduino_uno_r4_minima-pinctrl.dtsi"

/ {
	model = "Arduino Portenta C33 board";

	chosen {
		zephyr,console = &uart2;
		zephyr,shell-uart = &uart2;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};

	leds {
		compatible = "gpio-leds";
		led: led {
			gpios = <&ioport1 7 GPIO_ACTIVE_HIGH>;
		};
	};

	aliases {
		led0 = &led;
	};
};

&pinctrl {
	sci0_default: sci0_default {
		group1 {
			pinmux = <P410_RXD0>, <P411_TXD0>;
		};
	};
};

&sci0 {
	status = "okay";
	pinctrl-0 = <&sci0_default>;
	pinctrl-names = "default";
	uart0: uart {
		current-speed = <115200>;
		status = "okay";
	};
};

&ioport1 {
	status = "okay";
};

&fcu {
	status = "okay";
};

&hoco {
	status = "okay";
	clock-frequency = <48000000>;
};

&cgc {
	clock-source = <&hoco>;
	iclk-div = <1>;
	pclka-div = <1>;
	pclkb-div = <2>;
	pclkc-div = <1>;
	pclkd-div = <1>;
	fclk-div = <2>;
};
